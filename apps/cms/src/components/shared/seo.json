{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO-настройки",
    "description": "Мета-данные страницы для поисковиков и соцсетей"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text"
    },
    "keywords": {
      "type": "string"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "robotsNoIndex": {
      "type": "boolean",
      "default": false
    },
    "ogTitle": {
      "type": "string"
    },
    "ogDescription": {
      "type": "text"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
