{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Настройки сайта",
    "description": "Глобальные настройки сайта: метрики, скрипты и cookie-баннер"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "gtmContainerId": {
      "type": "string",
      "default": ""
    },
    "yandexMetrikaId": {
      "type": "string",
      "default": ""
    },
    "customHeadScript": {
      "type": "text"
    },
    "customBodyScript": {
      "type": "text"
    },
    "cookieBannerText": {
      "type": "text",
      "default": "Мы используем cookie, чтобы сайт работал корректно и для аналитики. Продолжая использовать сайт, вы соглашаетесь с"
    },
    "cookiePolicyUrl": {
      "type": "string",
      "default": "/privacy"
    }
  }
}
